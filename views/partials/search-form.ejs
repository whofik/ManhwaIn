<form action="/search" method="GET" class="hidden md:flex flex-1 max-w-md mx-auto">
    <div class="relative w-full group">
        <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-500 group-focus-within:text-brand-400 transition-colors"></i>
        <input name="q" value="<%= typeof query !== 'undefined' ? query : '' %>" placeholder="Cari manhwa, manhua, webtoon…" autocomplete="off"
            class="w-full bg-ink-850 border border-white/5 focus:border-brand-500/50 rounded-xl pl-10 pr-4 py-2.5 text-sm text-slate-100 placeholder-slate-500 outline-none transition focus:ring-2 focus:ring-brand-500/20">
    </div>
</form>