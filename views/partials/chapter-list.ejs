<div class="grid sm:grid-cols-2 gap-2 max-h-[28rem] overflow-y-auto scrollbar-thin pr-1">
    <% chapters.forEach(ch => { %>
        <a href="<%= ch.url %>" class="group flex items-center justify-between gap-3 px-4 py-3 rounded-xl bg-ink-900 border border-white/5 hover:border-brand-500/30 hover:bg-ink-850 transition">
            <span class="font-semibold text-slate-200 group-hover:text-brand-400 transition-colors truncate"><%= ch.chapterNum %></span>
            <span class="text-[11px] text-slate-500 whitespace-nowrap"><%= ch.date %></span>
        </a>
    <% }) %>
</div>