<%- include('partials/head', { title: 'ManhwaIn — Baca Manhwa Terlengkap & Terupdate' }) %>
<%- include('partials/navbar', { active: 'home' }) %>

<section class="reveal">
    <div class="flex items-center gap-3 mb-5">
        <span class="w-1.5 h-6 rounded-full bg-brand-600"></span>
        <h2 class="text-xl sm:text-2xl font-extrabold text-white">Sedang Populer</h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 sm:gap-5">
        <% popular.forEach(item => { %>
            <a href="<%= item.url %>" class="card-hover group block">
                <div class="relative rounded-2xl overflow-hidden bg-ink-850 border border-white/5 aspect-[2/3]">
                    <img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
                    <% if (item.rating) { %>
                        <div class="absolute top-2.5 left-2.5 flex items-center gap-1 bg-black/60 backdrop-blur px-2 py-1 rounded-lg text-[11px] font-bold text-amber-300">
                            <i class="fas fa-star"></i> <%= item.rating %>
                        </div>
                    <% } %>
                    <div class="absolute bottom-0 inset-x-0 p-2.5">
                        <p class="text-white text-xs font-semibold clamp-1"><%= item.chapter %></p>
                    </div>
                </div>
                <h3 class="mt-2 text-sm font-semibold text-slate-200 line-clamp-2 group-hover:text-brand-400 transition-colors"><%= item.title %></h3>
            </a>
        <% }) %>
    </div>
</section>

<section class="reveal mt-10">
    <div class="flex items-center gap-3 mb-5">
        <span class="w-1.5 h-6 rounded-full bg-brand-600"></span>
        <h2 class="text-xl sm:text-2xl font-extrabold text-white">Update Terbaru</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <% latest.forEach(item => { %>
            <article class="group flex gap-4 p-3 rounded-2xl bg-ink-900 border border-white/5 hover:border-brand-500/30 hover:bg-ink-850 transition card-hover">
                <a href="<%= item.url %>" class="shrink-0 w-24 sm:w-28 aspect-[2/3] rounded-xl overflow-hidden bg-ink-850">
                    <img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                </a>
                <div class="min-w-0 flex flex-col">
                    <a href="<%= item.url %>" class="font-bold text-white text-[15px] leading-snug clamp-2 group-hover:text-brand-400 transition-colors"><%= item.title %></a>
                    <div class="mt-2.5 flex flex-col gap-1.5 overflow-hidden">
                        <% item.chapters.slice(0, 3).forEach(ch => { %>
                            <a href="<%= ch.url %>" class="flex items-center justify-between gap-2 px-2.5 py-1.5 rounded-lg bg-ink-850 hover:bg-brand-600/20 border border-white/5 hover:border-brand-500/30 transition text-sm">
                                <span class="font-medium text-slate-200 truncate"><%= ch.chapter %></span>
                                <span class="text-[11px] text-slate-500 whitespace-nowrap"><%= ch.time %></span>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </article>
        <% }) %>
    </div>
</section>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>