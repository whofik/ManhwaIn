<%- include('partials/head', { title: `${data.title} — ManhwaIn` }) %>
<%- include('partials/navbar', { active: '' }) %>

<section class="reveal">
    <div class="flex flex-col sm:flex-row gap-6">
        <div class="shrink-0 mx-auto sm:mx-0 w-40 sm:w-52">
            <div class="rounded-2xl overflow-hidden bg-ink-850 border border-white/5 aspect-[2/3] shadow-xl">
                <img src="<%= data.thumbnail %>" alt="<%= data.title %>" class="w-full h-full object-cover">
            </div>
        </div>

        <div class="flex-1 min-w-0">
            <h1 class="text-2xl sm:text-3xl font-extrabold text-white leading-tight"><%= data.title %></h1>

            <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
                <span class="text-slate-400">Author: <span class="text-slate-200 font-medium"><%= data.author %></span></span>
                <span class="text-slate-400">Type: <span class="text-slate-200 font-medium"><%= data.type %></span></span>
                <span class="text-slate-400">Status:
                    <span class="font-semibold <%= data.status.toLowerCase() === 'ongoing' ? 'text-emerald-400' : 'text-sky-400' %>"><%= data.status %></span>
                </span>
            </div>

            <% if (data.genres && data.genres.length) { %>
                <div class="mt-4 flex flex-wrap gap-2">
                    <% data.genres.forEach(g => { %>
                        <a href="/genre/<%= g.toLowerCase().replace(/\s+/g,'-') %>" class="px-3 py-1 rounded-full text-xs font-medium bg-brand-600/15 text-brand-300 border border-brand-500/20 hover:bg-brand-600/25 transition"><%= g %></a>
                    <% }) %>
                </div>
            <% } %>

            <% if (data.synopsis) { %>
                <div class="mt-5">
                    <h3 class="text-xs font-bold uppercase tracking-wide text-slate-500 mb-1.5">Sinopsis</h3>
                    <p class="text-sm leading-relaxed text-slate-300"><%= data.synopsis %></p>
                </div>
            <% } %>
        </div>
    </div>

    <div class="mt-8">
        <div class="flex items-center gap-3 mb-4">
            <span class="w-1.5 h-6 rounded-full bg-brand-600"></span>
            <h2 class="text-lg sm:text-xl font-extrabold text-white">Daftar Chapter</h2>
            <span class="text-xs text-slate-500">(<%= data.chapters.length %> chapter)</span>
        </div>
        <%- include('partials/chapter-list', { chapters: data.chapters }) %>
    </div>
</section>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>