<%- include('partials/head', { title: `Pencarian: ${query} — ManhwaIn` }) %>
<%- include('partials/navbar', { active: '' }) %>

<section class="reveal">
    <div class="flex items-center gap-3 mb-6">
        <span class="w-1.5 h-6 rounded-full bg-brand-600"></span>
        <h1 class="text-xl sm:text-2xl font-extrabold text-white">Hasil untuk <span class="text-brand-400">“<%= query %>”</span></h1>
    </div>

    <% if (results && results.length > 0) { %>
        <%- include('partials/manga-grid', { items: results }) %>

        <% if (pagination.hasNext || pagination.currentPage > 1) { %>
            <div class="flex justify-center items-center gap-2 mt-10">
                <% if (pagination.currentPage > 1) { %>
                    <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= pagination.currentPage - 1 %>" class="px-4 py-2 rounded-xl bg-ink-850 border border-white/5 hover:bg-ink-800 text-slate-200 text-sm font-medium transition">Sebelumnya</a>
                <% } %>
                <span class="px-4 py-2 rounded-xl bg-brand-600 text-white text-sm font-bold"><%= pagination.currentPage %></span>
                <% if (pagination.hasNext) { %>
                    <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= pagination.currentPage + 1 %>" class="px-4 py-2 rounded-xl bg-ink-850 border border-white/5 hover:bg-ink-800 text-slate-200 text-sm font-medium transition">Selanjutnya</a>
                <% } %>
            </div>
        <% } %>
    <% } else { %>
        <div class="text-center py-20">
            <i class="fas fa-ghost text-6xl text-slate-700 mb-5"></i>
            <p class="text-slate-400 text-lg">Tidak ada manhwa yang cocok dengan pencarianmu.</p>
            <a href="/" class="inline-block mt-4 px-5 py-2.5 rounded-xl bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold transition">Kembali ke Beranda</a>
        </div>
    <% } %>
</section>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>